rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isRoomCode(id) {
      return id is string && id.size() == 4 && id.matches('^[A-Z]{4}$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidPlayer(data) {
      return data.keys().hasAll(['playerName', 'coins', 'uid', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.playerName is string && data.playerName.size() > 0 && data.playerName.size() <= 30 &&
             data.coins is number && data.coins >= 0 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 && data.uid == request.auth.uid &&
             data.updatedAt == request.time;
    }

    function isValidRoomSetting(settings) {
      return settings.keys().hasAll(['kelas', 'jumlahSoal']) &&
             settings.keys().size() == 2 &&
             settings.kelas is number && settings.kelas >= 1 && settings.kelas <= 6 &&
             settings.jumlahSoal is number && (settings.jumlahSoal == 10 || settings.jumlahSoal == 20 || settings.jumlahSoal == 30 || settings.jumlahSoal == 50);
    }

    function validateRoomPlayer(playerData) {
       return playerData.keys().hasAll(['uid', 'name', 'progress', 'score', 'isFinished', 'finishTime', 'isReady']) &&
              playerData.keys().size() == 7 &&
              playerData.uid is string && playerData.uid.size() > 0 &&
              playerData.name is string && playerData.name.size() > 0 &&
              playerData.progress is number && playerData.progress >= 0 &&
              playerData.score is number && playerData.score >= 0 &&
              playerData.isFinished is bool &&
              playerData.isReady is bool;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['roomCode', 'hostId', 'status', 'settings', 'players', 'questions', 'startTime', 'gameStartAtUnix']) &&
             data.keys().size() == 8 &&
             isRoomCode(data.roomCode) &&
             data.hostId is string && data.hostId.size() > 0 &&
             data.status in ['waiting', 'preparing', 'playing', 'finished'] &&
             data.settings is map && isValidRoomSetting(data.settings) &&
             data.players is list && data.players.size() > 0 && data.players.size() <= 6 &&
             data.questions is list &&
             (data.startTime == null || data.startTime is timestamp) &&
             (data.gameStartAtUnix == null || data.gameStartAtUnix is number) &&
             validateRoomPlayer(data.players[0]); // Check at least first element structure
    }

    match /players/{playerId} {
      allow get: if isSignedIn() && isValidId(playerId) && request.auth.uid == playerId;
      
      allow create: if isSignedIn() && isValidId(playerId) && request.auth.uid == playerId && isValidPlayer(incoming());
      
      allow update: if isSignedIn() && isValidId(playerId) && request.auth.uid == playerId && isValidPlayer(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['playerName', 'coins', 'updatedAt']) && incoming().uid == existing().uid)
      );
    }

    match /rooms/{roomId} {
      allow get: if isSignedIn() && isRoomCode(roomId);
      allow list: if isSignedIn();
      allow delete: if isSignedIn() && isRoomCode(roomId);

      allow create: if isSignedIn() && isRoomCode(roomId) && isValidRoom(incoming()) && 
                    incoming().hostId == request.auth.uid && 
                    incoming().status == 'waiting' &&
                    incoming().players.size() == 1 &&
                    incoming().players[0].uid == request.auth.uid;
      
      allow update: if isSignedIn() && isRoomCode(roomId) && isValidRoom(incoming()) && (
        // Action: Join Room or Player Leaves (Anyone can update players array regardless of status)
        (incoming().diff(existing()).affectedKeys().hasOnly(['players'])) ||
        
        // Action: Update status by any alive player or host when everyone finished
        (incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        
        // Action: Start Game or update status (Host only)
        (request.auth.uid == existing().hostId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'questions', 'startTime', 'gameStartAtUnix']))
      );
    }
  }
}
